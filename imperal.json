{
  "manifest_schema_version": 3,
  "sdk_version": "5.7.3",
  "app_id": "web-search",
  "version": "1.0.4",
  "name": "Web Search",
  "description": "Live web research for Webbee — search the web and read pages into clean Markdown. System capability: available to every chat, no setup.",
  "icon": "icon.svg",
  "actions_explicit": true,
  "system": true,
  "hidden_in_sidebar": true,
  "capabilities": [
    "store:read",
    "store:write"
  ],
  "tools": [
    {
      "name": "skeleton_refresh_web_search",
      "description": "Web Search status — the user's heavy-read policy (ask/always/never_heavy). Web research works with no setup: web_search to find pages, read_url to read them.",
      "scopes": [],
      "parameters": {}
    },
    {
      "name": "web_search",
      "description": "WEB SEARCH — find pages for a query. FIRST step of any web research: returns candidate cards (url, title, snippet, score) but does NOT read page content. The `snippet` is an LLM-ready excerpt and is OFTEN ENOUGH to answer — read pages only when you need more. Then read just the 2–3 BEST urls (not all results). For 'today'/'latest'/'recent' queries you MUST pass recency_days. Use include_domains to focus a site, category to bias content type. Re-run with new wording if thin.",
      "action_type": "read",
      "chain_callable": true,
      "effects": [],
      "id_projection": "",
      "params_schema": {
        "description": "Web search parameters.",
        "properties": {
          "query": {
            "description": "Search query in natural language.",
            "minLength": 1,
            "title": "Query",
            "type": "string"
          },
          "num_results": {
            "default": 10,
            "description": "How many candidate results to return.",
            "maximum": 50,
            "minimum": 1,
            "title": "Num Results",
            "type": "integer"
          },
          "include_domains": {
            "anyOf": [
              {
                "items": {
                  "type": "string"
                },
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "description": "Restrict results to these domains (e.g. ['docs.python.org']).",
            "title": "Include Domains"
          },
          "recency_days": {
            "anyOf": [
              {
                "maximum": 3650,
                "minimum": 1,
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "description": "Only results published within the last N days. REQUIRED for 'today'/'latest'/'recent' queries — ranking alone is NOT recency-sorted.",
            "title": "Recency Days"
          },
          "type": {
            "default": "auto",
            "description": "Search type — leave 'auto' unless you need speed (fast/instant).",
            "enum": [
              "auto",
              "fast",
              "instant",
              "deep-lite"
            ],
            "title": "Type",
            "type": "string"
          },
          "category": {
            "anyOf": [
              {
                "enum": [
                  "news",
                  "research paper",
                  "company",
                  "pdf",
                  "github",
                  "tweet",
                  "personal site",
                  "linkedin profile",
                  "financial report"
                ],
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "description": "Bias results toward a content category when the query clearly targets one.",
            "title": "Category"
          }
        },
        "required": [
          "query"
        ],
        "title": "WebSearchParams",
        "type": "object"
      },
      "return_schema": {
        "$defs": {
          "SearchResultItem": {
            "description": "One web-search candidate card (facts only — relevance is the LLM's job).",
            "properties": {
              "id": {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "integer"
                  }
                ],
                "title": "Id"
              },
              "title": {
                "title": "Title",
                "type": "string"
              },
              "kind": {
                "default": "search_result",
                "title": "Kind",
                "type": "string"
              },
              "subtitle": {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null,
                "title": "Subtitle"
              },
              "description": {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null,
                "title": "Description"
              },
              "status": {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null,
                "title": "Status"
              },
              "url": {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null,
                "title": "Url",
                "x-sdl-role": "ws.url"
              },
              "snippet": {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null,
                "title": "Snippet",
                "x-sdl-role": "ws.snippet"
              },
              "published_date": {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null,
                "title": "Published Date",
                "x-sdl-role": "ws.published_date"
              },
              "author": {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null,
                "title": "Author",
                "x-sdl-role": "ws.author"
              },
              "score": {
                "anyOf": [
                  {
                    "type": "number"
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null,
                "title": "Score",
                "x-sdl-role": "ws.score"
              },
              "engine": {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null,
                "title": "Engine",
                "x-sdl-role": "ws.engine"
              }
            },
            "required": [
              "id",
              "title"
            ],
            "title": "SearchResultItem",
            "type": "object",
            "x-sdl": "entity"
          }
        },
        "description": "web_search results — a real EntityList, never a dict wrapper.",
        "properties": {
          "items": {
            "items": {
              "$ref": "#/$defs/SearchResultItem"
            },
            "title": "Items",
            "type": "array"
          },
          "total": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Total"
          },
          "page": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Page"
          },
          "has_more": {
            "default": false,
            "title": "Has More",
            "type": "boolean"
          }
        },
        "required": [
          "items"
        ],
        "title": "SearchResultList",
        "type": "object",
        "x-sdl": "entity-list"
      },
      "event": "",
      "background": false,
      "long_running": false,
      "scopes": [],
      "owner_chat_tool": "tool_web_search_chat"
    },
    {
      "name": "read_url",
      "description": "READ ONE web page into clean Markdown — the cheap, default reader; ALWAYS try this before the heavy readers. TOKEN ECONOMY via `mode`: triage with mode='metadata' (~0 tok) or mode='outline' (~100 tok) BEFORE pulling mode='full'; mode='tables' for price/data pages. Each result includes `content_hash` — if you already read identical content this conversation, DON'T re-read it. Also returns `outline` and structured `tables` — use those, don't parse tables out of text. If it errors, read the NEXT candidate. If a page is blocked (JS/bot-protection) or is an Office doc, this returns a note pointing to the TOKEN-HEAVY read_url_rendered / read_document tools: tell the user what you found and ask before spending tokens (unless the policy is 'always').",
      "action_type": "read",
      "chain_callable": true,
      "effects": [],
      "id_projection": "",
      "params_schema": {
        "description": "Read-one-page parameters.",
        "properties": {
          "url": {
            "description": "URL to read (http/https).",
            "minLength": 1,
            "title": "Url",
            "type": "string"
          },
          "max_tokens": {
            "default": 8000,
            "description": "Token budget for the extracted content.",
            "maximum": 32000,
            "minimum": 200,
            "title": "Max Tokens",
            "type": "integer"
          },
          "query": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "description": "Optional: focus extraction/truncation on this question.",
            "title": "Query"
          },
          "mode": {
            "default": "full",
            "description": "TOKEN ECONOMY — what to return. full=whole page (expensive); main=prose only; outline=heading tree (~100 tok, 'which section?'); tables=only tables (price/data pages); metadata=no body (~0 tok, 'is it worth reading?'). Triage with metadata/outline FIRST, then full/tables on the winner.",
            "enum": [
              "full",
              "main",
              "outline",
              "tables",
              "metadata"
            ],
            "title": "Mode",
            "type": "string"
          }
        },
        "required": [
          "url"
        ],
        "title": "ReadUrlParams",
        "type": "object"
      },
